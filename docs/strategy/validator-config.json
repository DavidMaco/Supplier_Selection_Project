{
  "rounding": {
    "computed_decimals": 2,
    "declared_decimals": 1,
    "score_tolerance": 0.5
  },
  "traceability": {
    "strict_source_tags": true,
    "strict_source_type_enum": true,
    "strict_evidence_ids": true,
    "strict_evidence_prefix_enum": true,
    "strict_risk_linkage": true,
    "strict_freshness": true,
    "max_age_days": 365,
    "freshness_warning_window_days": 30,
    "source_type_max_age_days": {
      "InternalAudit": 180,
      "FinanceSignoff": 120,
      "CustomerAttestation": 180,
      "PMOReport": 120,
      "DataQualityAudit": 180,
      "ThirdPartyBenchmark": 270
    },
    "allowed_source_types": [
      "InternalAudit",
      "FinanceSignoff",
      "CustomerAttestation",
      "PMOReport",
      "DataQualityAudit",
      "ThirdPartyBenchmark"
    ],
    "evidence_prefix_max_age_days": {
      "BI": 120,
      "DA": 180,
      "RR": 180,
      "SC": 180,
      "OR": 90,
      "AX": 120,
      "CS": 120,
      "DM": 180
    },
    "allowed_evidence_prefixes": [
      "BI",
      "DA",
      "RR",
      "SC",
      "OR",
      "AX",
      "CS",
      "DM"
    ],
    "source_tag_pattern": "SourceTag=[A-Za-z]+:[A-Za-z0-9\\-]+",
    "evidence_id_pattern": "EvidenceID=[A-Z]{2}-\\d{2}",
    "data_as_of_pattern": "DataAsOf=\\d{4}-\\d{2}-\\d{2}"
  },
  "status_mapping": {
    "investable_rule": "score >= investable_threshold",
    "red_flag_rule": "score <= red_flag_threshold",
    "borderline_rule": "otherwise"
  }
}
